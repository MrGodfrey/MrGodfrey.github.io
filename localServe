import os
import time
import threading
import subprocess

WATCH_PATHS = ['content', 'templates', 'config.yaml']

def watch_and_generate():
    last_mtime = {}

    while True:
        changed = False
        for watch in WATCH_PATHS:
            if os.path.isfile(watch):
                paths = [watch]
            elif os.path.isdir(watch):
                paths = [
                    os.path.join(root, f)
                    for root, _, files in os.walk(watch)
                    for f in files
                ]
            else:
                continue
            for path in paths:
                try:
                    mtime = os.path.getmtime(path)
                except FileNotFoundError:
                    continue
                if path not in last_mtime or last_mtime[path] != mtime:
                    last_mtime[path] = mtime
                    changed = True
        if changed:
            print("Detected changes. Running generate.py...")
            subprocess.run(['python3', 'generate.py'])
        time.sleep(1)

def serve():
    print('Server at http://localhost:4000/')
    os.system("python3 -m http.server 4000")

if __name__ == "__main__":
    watcher = threading.Thread(target=watch_and_generate, daemon=True)
    watcher.start()
    serve()
